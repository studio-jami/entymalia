# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# --- Google OAuth / Service Account ---
# Service account key for server-side Google APIs.
GOOGLE_SA_JSON_KEY_PATH=/path/to/service-account.json
# WEB client — primary Supabase Google provider. This client (with its secret)
# holds the Supabase callback redirect URI: https://<ref>.supabase.co/auth/v1/callback
GOOGLE_WEB_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_SECRET=GOCSPX-xxxxxxxx
GOOGLE_WEB_CLIENT_SECRET_JSON_PATH=/path/to/client_secret_web.json
# ANDROID client — native Credential Manager ID-token flow (no secret).
# Registered in Supabase as an "Authorized Client ID", NOT the primary client.
GOOGLE_ANDROID_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# --- AI provider OAuth (Studio lane; obtained via one-time PKCE login, then refreshed) ---
# xAI (Grok) — OAuth only, no API key.
XAI_OAUTH_CLIENT_ID=
XAI_OAUTH_REFRESH_TOKEN=
XAI_OAUTH_TOKEN_ENDPOINT=https://auth.x.ai/oauth2/token
# OpenAI — OAuth only, no API key.
OPENAI_OAUTH_CLIENT_ID=
OPENAI_OAUTH_REFRESH_TOKEN=
OPENAI_OAUTH_TOKEN_ENDPOINT=https://auth.openai.com/api/accounts/oauth/token

# --- Background jobs ---
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxx

