# Etymalia web — local env example.
#
# On Vercel these are provided by the official Supabase <> Vercel integration.
# The app resolves the URL + client key from several possible names so it works
# whether the integration injects the legacy "ANON_KEY" or the newer
# "PUBLISHABLE_KEY" naming.
#
# Only the two NEXT_PUBLIC_* values are required for the client.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-only Stripe billing configuration. Create recurring Prices in Stripe,
# then set the six tier/interval entries. Stripe Checkout accepts
# dashboard-managed promotion codes; the hosted Billing Portal handles changes.
NEXT_PUBLIC_APP_URL=https://etymalia.jami.studio
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PERSONAL_MONTHLY=price_...
ETYMALIA_CREDITS_PERSONAL_MONTHLY=3
STRIPE_PRICE_ID_PERSONAL_YEARLY=price_...
ETYMALIA_CREDITS_PERSONAL_YEARLY=36
STRIPE_PRICE_ID_ENTREPRENEUR_MONTHLY=price_...
ETYMALIA_CREDITS_ENTREPRENEUR_MONTHLY=6
STRIPE_PRICE_ID_ENTREPRENEUR_YEARLY=price_...
ETYMALIA_CREDITS_ENTREPRENEUR_YEARLY=72
STRIPE_PRICE_ID_BUSINESS_MONTHLY=price_...
ETYMALIA_CREDITS_BUSINESS_MONTHLY=9
STRIPE_PRICE_ID_BUSINESS_YEARLY=price_...
ETYMALIA_CREDITS_BUSINESS_YEARLY=108

